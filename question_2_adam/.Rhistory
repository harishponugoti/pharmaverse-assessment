aeLast <- aeClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
AEDT = suppressWarnings(as.Date(substr(AESTDTC, 1, 10)))
) %>%
filter(!is.na(AEDT)) %>%
group_by(STUDYID, USUBJID) %>%
summarise(AELASTDT = max(AEDT, na.rm = TRUE), .groups = "drop")
dsLast <- dsClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
DSDT = suppressWarnings(as.Date(substr(DSSTDTC, 1, 10)))
) %>%
filter(!is.na(DSDT)) %>%
group_by(STUDYID, USUBJID) %>%
summarise(DSLASTDT = max(DSDT, na.rm = TRUE), .groups = "drop")
exLast <- exClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
EXDT = suppressWarnings(as.Date(substr(EXENDTC, 1, 10))),
validEX = !is.na(EXDT) & (EXDOSE > 0 | (EXDOSE == 0 & str_detect(EXTRT, "PLACEBO")))
) %>%
filter(validEX) %>%
group_by(STUDYID, USUBJID) %>%
summarise(EXLASTDT = max(EXDT, na.rm = TRUE), .groups = "drop")
# -------------------------------------------------------------------
# 10) Merge last-alive sources and derive LSTAVLDT
# -------------------------------------------------------------------
adslAlive1 <- adslItt %>% left_join(vsLast, by = c("STUDYID", "USUBJID"))
adslAlive2 <- adslAlive1 %>% left_join(aeLast, by = c("STUDYID", "USUBJID"))
adslAlive3 <- adslAlive2 %>% left_join(dsLast, by = c("STUDYID", "USUBJID"))
adslAlive4 <- adslAlive3 %>% left_join(exLast, by = c("STUDYID", "USUBJID"))
# pmax(..., na.rm = TRUE) gives the latest available date across all four sources.
# If all are missing, convert Inf back to NA.
adslLived <- adslAlive4 %>%
mutate(
LSTAVLDT = pmax(VSLASTDT, AELASTDT, DSLASTDT, EXLASTDT, na.rm = TRUE),
LSTAVLDT = if_else(is.infinite(LSTAVLDT), as.Date(NA), LSTAVLDT)
)
# -------------------------------------------------------------------
# 11) Final ADSL output
# -------------------------------------------------------------------
# Keep only required and useful subject-level variables.
adslOut <- adslLived %>%
select(
STUDYID, USUBJID, SUBJID,
SEX, RACE, COUNTRY, AGE,
AGEGR9, AGEGR9N,
ARM, ACTARM,
TRTSDTM, TRTSTMF, TRTSDT, TRTEDTM, TRTEDT, TRTDURD,
ITTFL, LSTAVLDT
)
# -------------------------------------------------------------------
# 12) Save output and log
# -------------------------------------------------------------------
outputDir <- file.path(getwd(), "output")
if (!dir.exists(outputDir)) dir.create(outputDir, recursive = TRUE, showWarnings = FALSE)
write_csv(adslOut, file.path(outputDir, "adsl.csv"))
logLines <- c(
"Question 2 ADSL dataset creation completed successfully.",
paste("Rows:", nrow(adslOut)),
paste("Columns:", ncol(adslOut)),
paste("Missing AGEGR9:", sum(is.na(adslOut$AGEGR9))),
paste("Missing AGEGR9N:", sum(is.na(adslOut$AGEGR9N))),
paste("Missing TRTSDTM:", sum(is.na(adslOut$TRTSDTM))),
paste("Missing TRTSTMF:", sum(is.na(adslOut$TRTSTMF))),
paste("Missing ITTFL:", sum(is.na(adslOut$ITTFL))),
paste("Missing LSTAVLDT:", sum(is.na(adslOut$LSTAVLDT)))
)
writeLines(logLines, file.path(outputDir, "adsl_run_log.txt"))
View(adslOut)
View(exDatetime)
View(exDatetime)
# -------------------------------------------------------------------
# Question 2 - ADSL creation
# Purpose: Create ADSL using pharmaversesdtm inputs and admiral logic
# Required derivations:
#   - AGEGR9, AGEGR9N
#   - TRTSDTM, TRTSTMF
#   - ITTFL
#   - LSTAVLDT
# Output:
#   - output/adsl.csv
#   - output/adsl_run_log.txt
# -------------------------------------------------------------------
# -------------------------------------------------------------------
# 1) Packages
# -------------------------------------------------------------------
requiredPackages <- c("admiral", "dplyr", "stringr", "lubridate", "readr", "pharmaversesdtm")
newPackages <- requiredPackages[!requiredPackages %in% installed.packages()[, "Package"]]
if (length(newPackages) > 0) install.packages(newPackages)
library(admiral)
library(dplyr)
library(stringr)
library(lubridate)
library(readr)
library(pharmaversesdtm)
# -------------------------------------------------------------------
# 2) Load SDTM source data
# -------------------------------------------------------------------
dmRaw <- pharmaversesdtm::dm
dsRaw <- pharmaversesdtm::ds
exRaw <- pharmaversesdtm::ex
aeRaw <- pharmaversesdtm::ae
vsRaw <- pharmaversesdtm::vs
# Convert blank character fields to NA for cleaner joins and derivations
dmClean <- dmRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
dsClean <- dsRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
exClean <- exRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
aeClean <- aeRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
vsClean <- vsRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
# -------------------------------------------------------------------
# 3) Base ADSL from DM
# -------------------------------------------------------------------
# DM is the parent dataset for ADSL.
adslBase <- dmClean %>%
select(-DOMAIN)
# -------------------------------------------------------------------
# 4) AGEGR9 and AGEGR9N
# -------------------------------------------------------------------
# Assignment categories:
#   <18, 18 - 50, >50
# Numeric mapping:
#   1, 2, 3
adslAge <- adslBase %>%
mutate(
AGEGR9 = case_when(
is.na(AGE) ~ NA_character_,
AGE < 18 ~ "<18",
AGE >= 18 & AGE <= 50 ~ "18 - 50",
AGE > 50 ~ ">50"
),
AGEGR9N = case_when(
is.na(AGE) ~ NA_integer_,
AGE < 18 ~ 1L,
AGE >= 18 & AGE <= 50 ~ 2L,
AGE > 50 ~ 3L
)
)
# -------------------------------------------------------------------
# 5) Prepare exposure datetimes
# -------------------------------------------------------------------
# EXSTDTC is the treatment start source.
# Time is imputed when missing.
# validDose follows the assignment rule:
#   - EXDOSE > 0
#   - OR EXDOSE = 0 and EXTRT contains "PLACEBO"
exDatetime <- exClean %>%
mutate(
validDose = EXDOSE > 0 | (EXDOSE == 0 & str_detect(EXTRT, "PLACEBO"))
) %>%
derive_vars_dtm(
dtc = EXSTDTC,
new_vars_prefix = "EXST",
date_imputation = "first",
time_imputation = "00:00:00",
ignore_seconds_flag = TRUE
) %>%
derive_vars_dtm(
dtc = EXENDTC,
new_vars_prefix = "EXEN",
date_imputation = "last",
time_imputation = "23:59:59"
)
# -------------------------------------------------------------------
# 6) TRTSDTM and TRTSTMF
# -------------------------------------------------------------------
# First valid exposure record defines treatment start.
adslTrt1 <- adslAge %>%
derive_vars_merged(
dataset_add = exDatetime,
by_vars = exprs(STUDYID, USUBJID),
filter_add = validDose & !is.na(EXSTDTM),
new_vars = exprs(TRTSDTM = EXSTDTM, TRTSTMF = EXSTTMF),
order = exprs(EXSTDTM, EXSEQ),
mode = "first"
)
# Optional treatment end datetime for LSTAVLDT support
adslTrt2 <- adslTrt1 %>%
derive_vars_merged(
dataset_add = exDatetime,
by_vars = exprs(STUDYID, USUBJID),
filter_add = validDose & !is.na(EXENDTM),
new_vars = exprs(TRTEDTM = EXENDTM, TRTETMF = EXENTMF),
order = exprs(EXENDTM, EXSEQ),
mode = "last"
)
# Keep treatment datetime as datetime; do not overwrite TRTSDTM with date-only conversion.
adslTrt3 <- adslTrt2 %>%
derive_vars_dtm_to_dt(source_vars = exprs(TRTEDTM))
# -------------------------------------------------------------------
# 7) ITTFL
# -------------------------------------------------------------------
# Randomized subjects are those with ARM populated.
adslItt <- adslTrt3 %>%
mutate(
ITTFL = if_else(!is.na(ARM) & ARM != "", "Y", "N")
)
# -------------------------------------------------------------------
# 8) Source dates for LSTAVLDT
# -------------------------------------------------------------------
# LSTAVLDT is the maximum of:
#   1) last complete vital sign date with a valid result
#   2) last AE start date
#   3) last DS disposition date
#   4) last valid exposure date
vsLast <- vsClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
VSDT = suppressWarnings(as.Date(substr(VSDTC, 1, 10))),
validVS = !is.na(VSDT) & (!is.na(VSSTRESN) | !is.na(VSSTRESC))
) %>%
filter(validVS) %>%
group_by(STUDYID, USUBJID) %>%
summarise(VSLASTDT = max(VSDT, na.rm = TRUE), .groups = "drop")
aeLast <- aeClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
AEDT = suppressWarnings(as.Date(substr(AESTDTC, 1, 10)))
) %>%
filter(!is.na(AEDT)) %>%
group_by(STUDYID, USUBJID) %>%
summarise(AELASTDT = max(AEDT, na.rm = TRUE), .groups = "drop")
dsLast <- dsClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
DSDT = suppressWarnings(as.Date(substr(DSSTDTC, 1, 10)))
) %>%
filter(!is.na(DSDT)) %>%
group_by(STUDYID, USUBJID) %>%
summarise(DSLASTDT = max(DSDT, na.rm = TRUE), .groups = "drop")
exLast <- exDatetime %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
EXDT = as.Date(as.character(EXENDTM)),
validEX = validDose & !is.na(EXENDTM)
) %>%
filter(validEX) %>%
group_by(STUDYID, USUBJID) %>%
summarise(EXLASTDT = max(EXDT, na.rm = TRUE), .groups = "drop")
# -------------------------------------------------------------------
# 9) Merge sources and derive LSTAVLDT
# -------------------------------------------------------------------
adslLast1 <- adslItt %>% left_join(vsLast, by = c("STUDYID", "USUBJID"))
adslLast2 <- adslLast1 %>% left_join(aeLast, by = c("STUDYID", "USUBJID"))
adslLast3 <- adslLast2 %>% left_join(dsLast, by = c("STUDYID", "USUBJID"))
adslLast4 <- adslLast3 %>% left_join(exLast, by = c("STUDYID", "USUBJID"))
adslLived <- adslLast4 %>%
mutate(
LSTAVLDT = pmax(VSLASTDT, AELASTDT, DSLASTDT, EXLASTDT, na.rm = TRUE),
LSTAVLDT = if_else(is.infinite(LSTAVLDT), as.Date(NA), LSTAVLDT)
)
# -------------------------------------------------------------------
# 10) Final ADSL output
# -------------------------------------------------------------------
adslOut <- adslLived %>%
select(
STUDYID, USUBJID, SUBJID,
SEX, RACE, COUNTRY, AGE,
AGEGR9, AGEGR9N,
ARM, ACTARM,
TRTSDTM, TRTSTMF, TRTEDTM, TRTETMF,
ITTFL, LSTAVLDT
)
# -------------------------------------------------------------------
# 11) Save output and log
# -------------------------------------------------------------------
outputDir <- file.path(getwd(), "output")
if (!dir.exists(outputDir)) dir.create(outputDir, recursive = TRUE, showWarnings = FALSE)
write_csv(adslOut, file.path(outputDir, "adsl.csv"))
logLines <- c(
"Question 2 ADSL creation completed successfully.",
paste("Rows:", nrow(adslOut)),
paste("Columns:", ncol(adslOut)),
paste("Missing AGEGR9:", sum(is.na(adslOut$AGEGR9))),
paste("Missing AGEGR9N:", sum(is.na(adslOut$AGEGR9N))),
paste("Missing TRTSDTM:", sum(is.na(adslOut$TRTSDTM))),
paste("Missing TRTSTMF:", sum(is.na(adslOut$TRTSTMF))),
paste("Missing ITTFL:", sum(is.na(adslOut$ITTFL))),
paste("Missing LSTAVLDT:", sum(is.na(adslOut$LSTAVLDT)))
)
writeLines(logLines, file.path(outputDir, "adsl_run_log.txt"))
View(adslOut)
# -------------------------------------------------------------------
# Question 2 - ADSL creation
# Purpose: Create ADSL using pharmaversesdtm source data and admiral logic
# Required derivations:
#   - AGEGR9, AGEGR9N
#   - TRTSDTM, TRTSTMF
#   - ITTFL
#   - LSTAVLDT
# Output:
#   - output/adsl.csv
#   - output/adsl_run_log.txt
# -------------------------------------------------------------------
# -------------------------------------------------------------------
# 1) Packages
# -------------------------------------------------------------------
requiredPackages <- c(
"admiral",
"dplyr",
"stringr",
"readr",
"lubridate",
"pharmaversesdtm"
)
newPackages <- requiredPackages[!requiredPackages %in% installed.packages()[, "Package"]]
if (length(newPackages) > 0) install.packages(newPackages)
library(admiral)
library(dplyr)
library(stringr)
library(readr)
library(lubridate)
library(pharmaversesdtm)
# -------------------------------------------------------------------
# 2) Load SDTM source datasets
# -------------------------------------------------------------------
dmRaw <- pharmaversesdtm::dm
exRaw <- pharmaversesdtm::ex
dsRaw <- pharmaversesdtm::ds
aeRaw <- pharmaversesdtm::ae
vsRaw <- pharmaversesdtm::vs
# Convert blank strings to NA for consistency
dmClean <- dmRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
exClean <- exRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
dsClean <- dsRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
aeClean <- aeRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
vsClean <- vsRaw %>% mutate(across(where(is.character), ~ na_if(.x, "")))
# -------------------------------------------------------------------
# 3) Base ADSL from DM
# -------------------------------------------------------------------
# DM is the subject-level base dataset for ADSL.
adslBase <- dmClean %>%
select(-DOMAIN)
# -------------------------------------------------------------------
# 4) Age group derivation
# -------------------------------------------------------------------
# Requested categories:
#   <18, 18 - 50, >50
# Numeric codes:
#   1, 2, 3
adslAge <- adslBase %>%
mutate(
AGEGR9 = case_when(
is.na(AGE) ~ NA_character_,
AGE < 18 ~ "<18",
AGE >= 18 & AGE <= 50 ~ "18 - 50",
AGE > 50 ~ ">50"
),
AGEGR9N = case_when(
is.na(AGE) ~ NA_integer_,
AGE < 18 ~ 1L,
AGE >= 18 & AGE <= 50 ~ 2L,
AGE > 50 ~ 3L
)
)
# -------------------------------------------------------------------
# 5) Exposure datetime preparation
# -------------------------------------------------------------------
# validDose is the assignment's valid dose rule.
# EXSTDTC is converted to datetime with time imputation.
# - missing time -> 00:00:00
# - partial time -> missing parts imputed with 00
# - seconds-only missing -> no TRTSTMF flag
exExt <- exClean %>%
mutate(
validDose = EXDOSE > 0 | (EXDOSE == 0 & str_detect(EXTRT, "PLACEBO"))
) %>%
derive_vars_dtm(
dtc = EXSTDTC,
new_vars_prefix = "EXST",
date_imputation = "first",
time_imputation = "00:00:00",
ignore_seconds_flag = TRUE
) %>%
derive_vars_dtm(
dtc = EXENDTC,
new_vars_prefix = "EXEN",
date_imputation = "last",
time_imputation = "23:59:59"
)
# -------------------------------------------------------------------
# 6) Treatment start and end datetime derivation
# -------------------------------------------------------------------
# First valid exposure record gives TRTSDTM/TRTSTMF.
# Last valid exposure record gives TRTEDTM/TRTETMF.
adslTrt1 <- adslAge %>%
derive_vars_merged(
dataset_add = exExt,
by_vars = exprs(STUDYID, USUBJID),
filter_add = validDose & !is.na(EXSTDTM),
new_vars = exprs(TRTSDTM = EXSTDTM, TRTSTMF = EXSTTMF),
order = exprs(EXSTDTM, EXSEQ),
mode = "first"
)
adslTrt2 <- adslTrt1 %>%
derive_vars_merged(
dataset_add = exExt,
by_vars = exprs(STUDYID, USUBJID),
filter_add = validDose & !is.na(EXENDTM),
new_vars = exprs(TRTEDTM = EXENDTM, TRTETMF = EXENTMF),
order = exprs(EXENDTM, EXSEQ),
mode = "last"
)
# Keep TRTSDTM as datetime; do not convert it to date.
adslTrtFinal <- adslTrt2
# -------------------------------------------------------------------
# 7) ITT flag
# -------------------------------------------------------------------
# Randomized subjects have ARM populated.
adslItt <- adslTrtFinal %>%
mutate(
ITTFL = if_else(!is.na(ARM) & ARM != "", "Y", "N")
)
# -------------------------------------------------------------------
# 8) Components for LSTAVLDT
# -------------------------------------------------------------------
# LSTAVLDT = max of:
#   - last valid vital sign date
#   - last AE start date
#   - last DS disposition date
#   - last valid exposure date
vsLast <- vsClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
VSDT = suppressWarnings(as.Date(substr(VSDTC, 1, 10))),
validVS = !is.na(VSDT) & (!is.na(VSSTRESN) | !is.na(VSSTRESC))
) %>%
filter(validVS) %>%
group_by(STUDYID, USUBJID) %>%
summarise(VSLASTDT = max(VSDT, na.rm = TRUE), .groups = "drop")
aeLast <- aeClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
AEDT = suppressWarnings(as.Date(substr(AESTDTC, 1, 10)))
) %>%
filter(!is.na(AEDT)) %>%
group_by(STUDYID, USUBJID) %>%
summarise(AELASTDT = max(AEDT, na.rm = TRUE), .groups = "drop")
dsLast <- dsClean %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
DSDT = suppressWarnings(as.Date(substr(DSSTDTC, 1, 10)))
) %>%
filter(!is.na(DSDT)) %>%
group_by(STUDYID, USUBJID) %>%
summarise(DSLASTDT = max(DSDT, na.rm = TRUE), .groups = "drop")
exLast <- exExt %>%
transmute(
STUDYID = as.character(STUDYID),
USUBJID = as.character(USUBJID),
EXDT = suppressWarnings(as.Date(substr(EXENDTC, 1, 10))),
validEX = validDose & !is.na(EXENDTM)
) %>%
filter(validEX) %>%
group_by(STUDYID, USUBJID) %>%
summarise(EXLASTDT = max(EXDT, na.rm = TRUE), .groups = "drop")
# -------------------------------------------------------------------
# 9) Merge source dates and derive LSTAVLDT
# -------------------------------------------------------------------
adslAlive1 <- adslItt %>% left_join(vsLast, by = c("STUDYID", "USUBJID"))
adslAlive2 <- adslAlive1 %>% left_join(aeLast, by = c("STUDYID", "USUBJID"))
adslAlive3 <- adslAlive2 %>% left_join(dsLast, by = c("STUDYID", "USUBJID"))
adslAlive4 <- adslAlive3 %>% left_join(exLast, by = c("STUDYID", "USUBJID"))
adslLived <- adslAlive4 %>%
mutate(
LSTAVLDT = pmax(VSLASTDT, AELASTDT, DSLASTDT, EXLASTDT, na.rm = TRUE),
LSTAVLDT = if_else(is.infinite(LSTAVLDT), as.Date(NA), LSTAVLDT)
)
# -------------------------------------------------------------------
# 10) Final output
# -------------------------------------------------------------------
adslOut <- adslLived %>%
select(
STUDYID, USUBJID, SUBJID,
SEX, RACE, COUNTRY, AGE,
AGEGR9, AGEGR9N,
ARM, ACTARM,
TRTSDTM, TRTSTMF, TRTEDTM, TRTETMF,
ITTFL, LSTAVLDT
)
# -------------------------------------------------------------------
# 11) Save output and log
# -------------------------------------------------------------------
outputDir <- file.path(getwd(), "output")
if (!dir.exists(outputDir)) {
dir.create(outputDir, recursive = TRUE, showWarnings = FALSE)
}
write_csv(adslOut, file.path(outputDir, "adsl.csv"))
logLines <- c(
"Question 2 ADSL dataset creation completed successfully.",
paste("Rows:", nrow(adslOut)),
paste("Columns:", ncol(adslOut)),
paste("Missing AGEGR9:", sum(is.na(adslOut$AGEGR9))),
paste("Missing AGEGR9N:", sum(is.na(adslOut$AGEGR9N))),
paste("Missing TRTSDTM:", sum(is.na(adslOut$TRTSDTM))),
paste("Missing TRTSTMF:", sum(is.na(adslOut$TRTSTMF))),
paste("Missing ITTFL:", sum(is.na(adslOut$ITTFL))),
paste("Missing LSTAVLDT:", sum(is.na(adslOut$LSTAVLDT)))
)
writeLines(logLines, file.path(outputDir, "adsl_run_log.txt"))
View(adslOut)
